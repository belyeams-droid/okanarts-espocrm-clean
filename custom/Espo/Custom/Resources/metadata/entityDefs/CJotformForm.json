{
    "fields": {
        "name": {
            "type": "varchar",
            "required": true,
            "pattern": "$noBadCharacters"
        },
        "description": {
            "type": "text"
        },
        "createdAt": {
            "type": "datetime",
            "readOnly": true
        },
        "modifiedAt": {
            "type": "datetime",
            "readOnly": true
        },
        "createdBy": {
            "type": "link",
            "readOnly": true,
            "view": "views/fields/user"
        },
        "modifiedBy": {
            "type": "link",
            "readOnly": true,
            "view": "views/fields/user"
        },
        "assignedUser": {
            "type": "link",
            "required": false,
            "view": "views/fields/assigned-user"
        },
        "teams": {
            "type": "linkMultiple",
            "view": "views/fields/teams"
        },
        "tours": {
            "type": "link",
            "tooltip": true,
            "required": true
        },
        "formId": {
            "type": "varchar",
            "required": true,
            "maxLength": 32,
            "options": [],
            "isCustom": true,
            "tooltip": true
        },
        "role": {
            "type": "enum",
            "required": true,
            "options": [
                "initial",
                "followup"
            ],
            "style": {
                "initial": null,
                "followup": null
            },
            "default": "initial",
            "maxLength": 100,
            "isCustom": true
        },
        "active": {
            "notNull": true,
            "type": "bool",
            "default": true,
            "isCustom": true
        },
        "initialized": {
            "notNull": true,
            "type": "bool",
            "tooltip": true,
            "isCustom": true
        },
        "apiKey": {
            "type": "varchar",
            "maxLength": 255,
            "options": [],
            "isCustom": true,
            "tooltip": true
        },
        "urlCode": {
            "type": "varchar",
            "required": false,
            "maxLength": 100,
            "options": [],
            "tooltip": true,
            "isCustom": true
        },
        "booking": {
            "type": "link"
        }
    },
    "links": {
        "createdBy": {
            "type": "belongsTo",
            "entity": "User"
        },
        "modifiedBy": {
            "type": "belongsTo",
            "entity": "User"
        },
        "assignedUser": {
            "type": "belongsTo",
            "entity": "User"
        },
        "teams": {
            "type": "hasMany",
            "entity": "Team",
            "relationName": "entityTeam",
            "layoutRelationshipsDisabled": true
        },
        "tours": {
            "type": "belongsTo",
            "foreign": "jotformForms",
            "entity": "CTours",
            "audited": false,
            "isCustom": true
        },
        "booking": {
            "type": "belongsTo",
            "foreign": "jotformForms",
            "entity": "CBooking",
            "audited": false,
            "isCustom": true
        },
        "bookings": {
            "type": "hasMany",
            "foreign": "jotformForm",
            "entity": "CBooking",
            "audited": false,
            "isCustom": true
        }
    },
    "collection": {
        "orderBy": "createdAt",
        "order": "desc"
    },
    "indexes": {
        "name": {
            "columns": [
                "name",
                "deleted"
            ]
        },
        "assignedUser": {
            "columns": [
                "assignedUserId",
                "deleted"
            ]
        },
        "createdAt": {
            "columns": [
                "createdAt"
            ]
        },
        "createdAtId": {
            "unique": true,
            "columns": [
                "createdAt",
                "id"
            ]
        }
    }
}