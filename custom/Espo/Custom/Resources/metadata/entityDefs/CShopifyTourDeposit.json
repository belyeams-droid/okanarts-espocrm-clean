{
    "fields": {
        "daysWaiting": {
            "type": "int",
            "readOnly": true,
            "notStorable": true
        },
        "name": {
            "type": "varchar",
            "required": true,
            "pattern": "$noBadCharacters"
        },
        "description": {
            "type": "text"
        },
        "createdAt": {
            "type": "datetime",
            "readOnly": true
        },
        "modifiedAt": {
            "type": "datetime",
            "readOnly": true
        },
        "createdBy": {
            "type": "link",
            "readOnly": true,
            "view": "views/fields/user"
        },
        "modifiedBy": {
            "type": "link",
            "readOnly": true,
            "view": "views/fields/user"
        },
        "assignedUser": {
            "type": "link",
            "required": false,
            "view": "views/fields/assigned-user"
        },
        "teams": {
            "type": "linkMultiple",
            "view": "views/fields/teams"
        },
        "shopifyOrderId": {
            "type": "varchar",
            "maxLength": 100,
            "options": [],
            "isCustom": true
        },
        "amount": {
            "type": "currency",
            "isCustom": true
        },
        "orderDate": {
            "notNull": false,
            "type": "datetime",
            "minuteStep": 30,
            "isCustom": true
        },
        "productTitle": {
            "type": "varchar",
            "maxLength": 100,
            "options": [],
            "isCustom": true
        },
        "contact": {
            "type": "link"
        },
        "shopifyEmail": {
            "type": "varchar",
            "maxLength": 100,
            "options": [],
            "isCustom": true
        },
        "detectionMethod": {
            "type": "enum",
            "options": [
                "price-rule",
                "fallback-email",
                "manual"
            ],
            "style": {
                "price-rule": null,
                "fallback-email": null,
                "manual": null
            },
            "default": "price-rule",
            "maxLength": 100,
            "isCustom": true
        },
        "shopifySku": {
            "type": "varchar",
            "maxLength": 100,
            "options": [],
            "isCustom": true
        },
        "booking": {
            "type": "link"
        },
        "tour": {
            "type": "link",
            "entity": "CTours",
            "isCustom": true
        },
        "touchFlag": {
            "notNull": true,
            "type": "bool",
            "isCustom": true
        },
        "contractStatus": {
            "type": "enum",
            "options": [
                "Deposit Received",
                "Contract Sent",
                "Contract Received",
                "Booking Created",
                "Customer Requires Attention",
                "Cancelled"
            ],
            "style": {
                "Deposit Received": "success",
                "Contract Sent": "info",
                "Contract Received": "success",
                "Booking Created": "primary",
                "Customer Requires Attention": "warning",
                "Cancelled": null
            },
            "default": "Deposit Received",
            "maxLength": 100,
            "isCustom": true
        },
        "contractSentAt": {
            "type": "datetime",
            "dbName": "contract_sent_at",
            "isCustom": true
        },
        "contractReceivedAt": {
            "type": "datetime",
            "dbName": "contract_received_at",
            "isCustom": true
        },
        "shopifyLineItemId": {
            "type": "varchar",
            "maxLength": 100,
            "options": [],
            "isCustom": true
        },
        "tourCode": {
            "type": "varchar",
            "maxLength": 100,
            "options": [],
            "isCustom": true
        }
    },
    "links": {
        "createdBy": {
            "type": "belongsTo",
            "entity": "User"
        },
        "modifiedBy": {
            "type": "belongsTo",
            "entity": "User"
        },
        "assignedUser": {
            "type": "belongsTo",
            "entity": "User"
        },
        "teams": {
            "type": "hasMany",
            "entity": "Team",
            "relationName": "entityTeam",
            "layoutRelationshipsDisabled": true
        },
        "contact": {
            "type": "belongsTo",
            "foreign": "cShopifyTourDeposits",
            "entity": "Contact",
            "audited": false,
            "isCustom": true
        },
        "booking": {
            "type": "belongsTo",
            "foreign": "shopifyTourDeposits",
            "entity": "CBooking",
            "audited": false,
            "isCustom": true
        },
        "tour": {
            "type": "belongsTo",
            "foreign": "shopifyTourDeposits",
            "entity": "CTours",
            "audited": false,
            "isCustom": true
        }
    },
    "collection": {
        "orderBy": "createdAt",
        "order": "desc"
    },
    "indexes": {
        "name": {
            "columns": [
                "name",
                "deleted"
            ]
        },
        "assignedUser": {
            "columns": [
                "assignedUserId",
                "deleted"
            ]
        },
        "createdAt": {
            "columns": [
                "createdAt"
            ]
        },
        "createdAtId": {
            "unique": true,
            "columns": [
                "createdAt",
                "id"
            ]
        }
    }
}